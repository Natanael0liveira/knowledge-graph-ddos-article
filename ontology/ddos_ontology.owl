        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>explanation</rdfs:label>
        <rdfs:comment>Human-readable explanation of the detection</rdfs:comment>
    </owl:DatatypeProperty>

