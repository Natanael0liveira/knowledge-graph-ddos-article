        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>confidence</rdfs:label>
        <rdfs:comment>Confidence level between 0 and 1</rdfs:comment>
    </owl:DatatypeProperty>
    
