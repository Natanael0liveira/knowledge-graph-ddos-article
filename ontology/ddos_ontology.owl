<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://security.example.org/ontology/ddos#"
     xml:base="http://security.example.org/ontology/ddos"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
     
    <owl:Ontology rdf:about="http://security.example.org/ontology/ddos">
        <dc:title>Layer 7 DDoS Attack Detection Ontology</dc:title>
        <dc:description>An ontology for modeling Layer 7 DDoS attacks in web applications using knowledge graphs</dc:description>
        <dc:version>2.0</dc:version>
        <rdfs:comment>This ontology supports semantic-based anomaly detection for Layer 7 DDoS attacks with focus on application behavior, endpoints, sessions, and explainability</rdfs:comment>
    </owl:Ontology>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Application Layer Classes (Layer 7 Focus)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <!-- HTTP Request Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#HTTPRequest">
        <rdfs:label>HTTP Request</rdfs:label>
        <rdfs:comment>An HTTP request with method, path, headers, and body</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#HTTPMethod">
        <rdfs:label>HTTP Method</rdfs:label>
        <rdfs:comment>HTTP methods: GET, POST, PUT, DELETE, etc.</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#HTTPHeader">
        <rdfs:label>HTTP Header</rdfs:label>
        <rdfs:comment>HTTP request/response headers</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#UserAgent">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#HTTPHeader"/>
        <rdfs:label>User Agent</rdfs:label>
        <rdfs:comment>User-Agent header identifying the client</rdfs:comment>
    </owl:Class>

    <!-- Endpoint Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Endpoint">
        <rdfs:label>Endpoint</rdfs:label>
        <rdfs:comment>A web application endpoint/route</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#LoginEndpoint">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>Login Endpoint</rdfs:label>
        <rdfs:comment>Authentication endpoint</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#SearchEndpoint">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>Search Endpoint</rdfs:label>
        <rdfs:comment>Search functionality endpoint</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#CheckoutEndpoint">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>Checkout Endpoint</rdfs:label>
        <rdfs:comment>E-commerce checkout endpoint</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#APIEndpoint">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>API Endpoint</rdfs:label>
        <rdfs:comment>REST or GraphQL API endpoint</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#GraphQLEndpoint">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#APIEndpoint"/>
        <rdfs:label>GraphQL Endpoint</rdfs:label>
        <rdfs:comment>GraphQL API endpoint</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#DynamicEndpoint">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>Dynamic Endpoint</rdfs:label>
        <rdfs:comment>Endpoint that requires server-side processing</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#StaticEndpoint">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>Static Endpoint</rdfs:label>
        <rdfs:comment>Endpoint serving static content</rdfs:comment>
    </owl:Class>

    <!-- Session and Authentication Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#ApplicationSession">
        <rdfs:label>Application Session</rdfs:label>
        <rdfs:comment>A user session with associated tokens, cookies, and state</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#SessionToken">
        <rdfs:label>Session Token</rdfs:label>
        <rdfs:comment>Session identifier token (JWT, session ID, etc.)</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Cookie">
        <rdfs:label>Cookie</rdfs:label>
        <rdfs:comment>HTTP cookie</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#AuthenticationContext">
        <rdfs:label>Authentication Context</rdfs:label>
        <rdfs:comment>Authentication state and credentials</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Identity">
        <rdfs:label>Identity</rdfs:label>
        <rdfs:comment>User identity (username, email, user ID)</rdfs:comment>
    </owl:Class>

    <!-- Behavior Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Behavior">
        <rdfs:label>Behavior</rdfs:label>
        <rdfs:comment>Observed behavior pattern</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#UserBehavior">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Behavior"/>
        <rdfs:label>User Behavior</rdfs:label>
        <rdfs:comment>Legitimate user behavior patterns</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#BotBehavior">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Behavior"/>
        <rdfs:label>Bot Behavior</rdfs:label>
        <rdfs:comment>Automated bot behavior patterns</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#NavigationPattern">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Behavior"/>
        <rdfs:label>Navigation Pattern</rdfs:label>
        <rdfs:comment>Pattern of page/endpoint navigation</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#RequestPattern">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Behavior"/>
        <rdfs:label>Request Pattern</rdfs:label>
        <rdfs:comment>Pattern of HTTP requests</rdfs:comment>
    </owl:Class>

    <!-- Layer 7 Attack Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Attack">
        <rdfs:label>Attack</rdfs:label>
        <rdfs:comment>A cyber attack</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#DDoSAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Attack"/>
        <rdfs:label>DDoS Attack</rdfs:label>
        <rdfs:comment>Distributed Denial of Service attack</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#ApplicationLayerAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#DDoSAttack"/>
        <rdfs:label>Application Layer Attack</rdfs:label>
        <rdfs:comment>DDoS attack targeting Layer 7 (Application)</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#HTTPFlood">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#ApplicationLayerAttack"/>
        <rdfs:label>HTTP Flood Attack</rdfs:label>
        <rdfs:comment>Flood of HTTP requests overwhelming the application</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#LoginFlood">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#ApplicationLayerAttack"/>
        <rdfs:label>Login Flood Attack</rdfs:label>
        <rdfs:comment>Flood of login attempts targeting authentication</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#SlowRequestAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#ApplicationLayerAttack"/>
        <rdfs:label>Slow Request Attack</rdfs:label>
        <rdfs:comment>Slow attacks consuming server resources (Slowloris, RUDY)</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Slowloris">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#SlowRequestAttack"/>
        <rdfs:label>Slowloris Attack</rdfs:label>
        <rdfs:comment>Slow HTTP attack keeping connections open</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#RUDY">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#SlowRequestAttack"/>
        <rdfs:label>R-U-Dead-Yet Attack</rdfs:label>
        <rdfs:comment>Slow POST attack</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#APIAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#ApplicationLayerAttack"/>
        <rdfs:label>API Abuse Attack</rdfs:label>
        <rdfs:comment>Abuse of API endpoints</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#ScrapingAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#ApplicationLayerAttack"/>
        <rdfs:label>Scraping Attack</rdfs:label>
        <rdfs:comment>Aggressive web scraping causing resource exhaustion</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#CacheBypassAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#ApplicationLayerAttack"/>
        <rdfs:label>Cache Bypass Attack</rdfs:label>
        <rdfs:comment>Attack bypassing cache to hit origin server</rdfs:comment>
    </owl:Class>

    <!-- Legacy Attack Classes (for compatibility) -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#VolumetricAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#DDoSAttack"/>
        <rdfs:label>Volumetric Attack</rdfs:label>
        <rdfs:comment>DDoS attack that overwhelms bandwidth</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#ProtocolAttack">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#DDoSAttack"/>
        <rdfs:label>Protocol Attack</rdfs:label>
        <rdfs:comment>DDoS attack exploiting protocol weaknesses</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#SYNFlood">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#ProtocolAttack"/>
        <rdfs:label>SYN Flood Attack</rdfs:label>
    </owl:Class>

    <!-- Mitigation Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Mitigation">
        <rdfs:label>Mitigation</rdfs:label>
        <rdfs:comment>Defense or mitigation mechanism</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#WAFRule">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Mitigation"/>
        <rdfs:label>WAF Rule</rdfs:label>
        <rdfs:comment>Web Application Firewall rule</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#RateLimitPolicy">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Mitigation"/>
        <rdfs:label>Rate Limit Policy</rdfs:label>
        <rdfs:comment>Rate limiting configuration</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#ChallengeResponse">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Mitigation"/>
        <rdfs:label>Challenge-Response</rdfs:label>
        <rdfs:comment>CAPTCHA or JavaScript challenge</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#BotManagement">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Mitigation"/>
        <rdfs:label>Bot Management</rdfs:label>
        <rdfs:comment>Bot detection and management system</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#CacheLayer">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Mitigation"/>
        <rdfs:label>Cache Layer</rdfs:label>
        <rdfs:comment>Caching layer (CDN, reverse proxy)</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#CircuitBreaker">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Mitigation"/>
        <rdfs:label>Circuit Breaker</rdfs:label>
        <rdfs:comment>Circuit breaker pattern for fault tolerance</rdfs:comment>
    </owl:Class>

    <!-- Backend Resource Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#BackendResource">
        <rdfs:label>Backend Resource</rdfs:label>
        <rdfs:comment>Backend server resource</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Database">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#BackendResource"/>
        <rdfs:label>Database</rdfs:label>
        <rdfs:comment>Database server</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#ApplicationServer">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#BackendResource"/>
        <rdfs:label>Application Server</rdfs:label>
        <rdfs:comment>Application server process</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#WorkerPool">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#BackendResource"/>
        <rdfs:label>Worker Pool</rdfs:label>
        <rdfs:comment>Worker thread/process pool</rdfs:comment>
    </owl:Class>

    <!-- Anomaly and Signal Classes -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Anomaly">
        <rdfs:label>Anomaly</rdfs:label>
        <rdfs:comment>A detected deviation from normal behavior</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#AnomalySignal">
        <rdfs:label>Anomaly Signal</rdfs:label>
        <rdfs:comment>A signal indicating potential anomaly</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#RateAnomalySignal">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#AnomalySignal"/>
        <rdfs:label>Rate Anomaly Signal</rdfs:label>
        <rdfs:comment>Abnormal request rate signal</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#LatencyAnomalySignal">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#AnomalySignal"/>
        <rdfs:label>Latency Anomaly Signal</rdfs:label>
        <rdfs:comment>Abnormal latency signal</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#ErrorRateSignal">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#AnomalySignal"/>
        <rdfs:label>Error Rate Signal</rdfs:label>
        <rdfs:comment>Abnormal error rate signal (4xx, 5xx)</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#SessionAnomalySignal">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#AnomalySignal"/>
        <rdfs:label>Session Anomaly Signal</rdfs:label>
        <rdfs:comment>Abnormal session behavior signal</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#FingerprintAnomalySignal">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#AnomalySignal"/>
        <rdfs:label>Fingerprint Anomaly Signal</rdfs:label>
        <rdfs:comment>Abnormal browser/client fingerprint signal</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Alert">
        <rdfs:label>Alert</rdfs:label>
        <rdfs:comment>A security alert generated by the system</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#DetectionRule">
        <rdfs:label>Detection Rule</rdfs:label>
        <rdfs:comment>A semantic rule for anomaly detection</rdfs:comment>
    </owl:Class>

    <!-- Network Infrastructure Classes (Legacy Support) -->
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#NetworkEntity">
        <rdfs:label>Network Entity</rdfs:label>
        <rdfs:comment>Base class for all network entities</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Host">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#NetworkEntity"/>
        <rdfs:label>Host</rdfs:label>
        <rdfs:comment>A computing device on the network</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Server">
        <rdfs:subClassOf rdf:resource="http://security.example.org/ontology/ddos#Host"/>
        <rdfs:label>Server</rdfs:label>
        <rdfs:comment>A host that provides services to other hosts</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#IPAddress">
        <rdfs:label>IP Address</rdfs:label>
        <rdfs:comment>An Internet Protocol address</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Botnet">
        <rdfs:label>Botnet</rdfs:label>
        <rdfs:comment>A network of compromised devices used for attacks</rdfs:comment>
    </owl:Class>
    
    <owl:Class rdf:about="http://security.example.org/ontology/ddos#Bot">
        <rdfs:label>Bot</rdfs:label>
        <rdfs:comment>A compromised device in a botnet</rdfs:comment>
    </owl:Class>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties (Relations) - Layer 7 Specific
    //
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <!-- Endpoint Relations -->
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#targetsEndpoint">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#Attack"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>targets endpoint</rdfs:label>
        <rdfs:comment>Indicates which endpoint is being attacked</rdfs:comment>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#abusesFunction">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#Attack"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>abuses function</rdfs:label>
        <rdfs:comment>Indicates which application function is being abused</rdfs:comment>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#hasEndpoint">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#HTTPRequest"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:label>has endpoint</rdfs:label>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#requiresAuthentication">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#AuthenticationContext"/>
        <rdfs:label>requires authentication</rdfs:label>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#dependsOnDatabase">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#Endpoint"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Database"/>
        <rdfs:label>depends on database</rdfs:label>
    </owl:ObjectProperty>

    <!-- Session Relations -->
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#hasSession">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#HTTPRequest"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#ApplicationSession"/>
        <rdfs:label>has session</rdfs:label>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#hasToken">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#ApplicationSession"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#SessionToken"/>
        <rdfs:label>has token</rdfs:label>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#hasCookie">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#ApplicationSession"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Cookie"/>
        <rdfs:label>has cookie</rdfs:label>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#belongsToIdentity">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#ApplicationSession"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Identity"/>
        <rdfs:label>belongs to identity</rdfs:label>
    </owl:ObjectProperty>

    <!-- Behavior Relations -->
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#exhibitsBehavior">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#ApplicationSession"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Behavior"/>
        <rdfs:label>exhibits behavior</rdfs:label>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#resemblesLegitimateTraffic">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#Attack"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#UserBehavior"/>
        <rdfs:label>resembles legitimate traffic</rdfs:label>
        <rdfs:comment>Indicates how much the attack mimics legitimate behavior</rdfs:comment>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="http://security.example.org/ontology/ddos#deviatesFrom">
        <rdfs:domain rdf:resource="http://security.example.org/ontology/ddos#Behavior"/>
        <rdfs:range rdf:resource="http://security.example.org/ontology/ddos#Behavior"/>
        <rdfs:label>deviates from</rdfs:label>
    </owl:ObjectProperty>

