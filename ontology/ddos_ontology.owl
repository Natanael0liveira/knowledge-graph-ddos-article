        <rdfs:label>is known malicious</rdfs:label>
    </owl:DatatypeProperty>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // SWRL Rules (Semantic Web Rule Language) - Layer 7 Specific
    //
    ///////////////////////////////////////////////////////////////////////////////////////
    -->

    <!-- Rule: Login Flood Detection -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#LoginFloodRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: High number of failed login attempts from same identity or session.
            
            SWRL representation:
            ApplicationSession(?session) ^ belongsToIdentity(?session, ?identity) ^
            failedLogins(?session, ?count) ^ greaterThan(?count, 10) ^
            timestamp(?session, ?time) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, LoginFlood) ^
            triggeredBy(?anomaly, ?session) ^ anomalyScore(?anomaly, 0.85)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: HTTP Flood Detection -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#HTTPFloodRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: Abnormal request rate per session or token targeting same endpoint.
            
            SWRL representation:
            ApplicationSession(?session) ^ hasEndpoint(?request, ?endpoint) ^
            requestCount(?session, ?count) ^ sessionAge(?session, ?age) ^
            divide(?count, ?age, ?rate) ^ greaterThan(?rate, 100) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, HTTPFlood) ^
            triggeredBy(?anomaly, ?session) ^ anomalyScore(?anomaly, 0.8)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Bot Behavior Detection -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#BotBehaviorRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: Low variability in headers, fingerprint, or navigation patterns.
            
            SWRL representation:
            Behavior(?behavior) ^ exhibitsBehavior(?session, ?behavior) ^
            headerVariability(?behavior, ?hv) ^ lessThan(?hv, 0.1) ^
            fingerprintVariability(?behavior, ?fv) ^ lessThan(?fv, 0.1) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, BotBehavior) ^
            triggeredBy(?anomaly, ?behavior) ^ anomalyScore(?anomaly, 0.75)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Low Session Value Attack -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#LowSessionValueRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: High request count with low session value indicates API abuse.
            
            SWRL representation:
            ApplicationSession(?session) ^ requestCount(?session, ?count) ^
            sessionValue(?session, ?value) ^ greaterThan(?count, 100) ^
            lessThan(?value, 0.1) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, APIAttack) ^
            triggeredBy(?anomaly, ?session) ^ anomalyScore(?anomaly, 0.7)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Expensive Endpoint Burst -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#ExpensiveEndpointBurstRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: Burst of requests to computationally expensive endpoints.
            
            SWRL representation:
            Endpoint(?endpoint) ^ computationalCost(?endpoint, ?cost) ^
            greaterThan(?cost, 0.7) ^ hasEndpoint(?request, ?endpoint) ^
            requestsPerSecond(?endpoint, ?rate) ^ greaterThan(?rate, 50) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, ApplicationLayerAttack) ^
            targetsEndpoint(?anomaly, ?endpoint) ^ anomalyScore(?anomaly, 0.9)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Latency Increase Detection -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#LatencyIncreaseRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: Significant latency increase on specific endpoint indicates attack impact.
            
            SWRL representation:
            Endpoint(?endpoint) ^ averageResponseTime(?endpoint, ?avgTime) ^
            responseTime(?request, ?actualTime) ^ hasEndpoint(?request, ?endpoint) ^
            multiply(?avgTime, 3, ?threshold) ^ greaterThan(?actualTime, ?threshold) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, ApplicationLayerAttack) ^
            increasesLatency(?anomaly, ?endpoint) ^ anomalyScore(?anomaly, 0.6)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Repetitive Route Pattern -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#RepetitiveRouteRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: High repetition of same route with low navigation diversity.
            
            SWRL representation:
            ApplicationSession(?session) ^ exhibitsBehavior(?session, ?behavior) ^
            navigationDiversity(?behavior, ?div) ^ lessThan(?div, 0.2) ^
            requestCount(?session, ?count) ^ greaterThan(?count, 50) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, BotBehavior) ^
            triggeredBy(?anomaly, ?behavior) ^ anomalyScore(?anomaly, 0.7)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Cache Bypass Attack -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#CacheBypassRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: Requests bypassing cache to hit origin on cacheable endpoints.
            
            SWRL representation:
            Endpoint(?endpoint) ^ isCacheable(?endpoint, true) ^
            cachedBy(?endpoint, ?cache) ^ hasEndpoint(?request, ?endpoint) ^
            httpHeader(?request, "Cache-Control", "no-cache") ->
            Anomaly(?anomaly) ^ indicates(?anomaly, CacheBypassAttack) ^
            targetsEndpoint(?anomaly, ?endpoint) ^ anomalyScore(?anomaly, 0.65)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Slow Request Attack -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#SlowRequestRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: Very slow requests consuming server resources.
            
            SWRL representation:
            HTTPRequest(?request) ^ responseTime(?request, ?time) ^
            greaterThan(?time, 30000) ^ httpMethod(?request, "POST") ->
            Anomaly(?anomaly) ^ indicates(?anomaly, SlowRequestAttack) ^
            triggeredBy(?anomaly, ?request) ^ anomalyScore(?anomaly, 0.75)
        </rdfs:comment>
    </owl:NamedIndividual>

    <!-- Rule: Scraping Detection -->
    <owl:NamedIndividual rdf:about="http://security.example.org/ontology/ddos#ScrapingRule">
        <rdf:type rdf:resource="http://security.example.org/ontology/ddos#DetectionRule"/>
        <rdfs:comment>
            Rule: Systematic access to multiple endpoints with bot-like patterns.
            
            SWRL representation:
            ApplicationSession(?session) ^ uniqueEndpointsVisited(?session, ?endpoints) ^
            greaterThan(?endpoints, 100) ^ exhibitsBehavior(?session, ?behavior) ^
            isBotLike(?behavior, true) ->
            Anomaly(?anomaly) ^ indicates(?anomaly, ScrapingAttack) ^
            triggeredBy(?anomaly, ?session) ^ anomalyScore(?anomaly, 0.8)
        </rdfs:comment>
    </owl:NamedIndividual>

</rdf:RDF>
